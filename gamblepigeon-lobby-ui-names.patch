+
+.modal-backdrop {
+    position: fixed;
+    inset: 0;
+    z-index: 20;
+    display: grid;
+    place-items: center;
+    padding: 24px;
+    background: rgba(2, 6, 23, 0.72);
+    backdrop-filter: blur(10px);
+}
+
+.modal-card {
+    width: min(760px, 100%);
+    max-height: min(720px, 90vh);
+    overflow: auto;
+    background: #1e293b;
+    border: 1px solid #475569;
+    border-radius: 24px;
+    box-shadow: 0 24px 90px rgba(0, 0, 0, 0.45);
+    padding: 22px;
+}
+
+.compact-modal {
+    width: min(460px, 100%);
+}
+
+.modal-header {
+    display: flex;
+    justify-content: space-between;
+    gap: 16px;
+    align-items: flex-start;
+    margin-bottom: 22px;
+}
+
+.modal-header h2 {
+    margin: 2px 0 0;
+    font-size: 28px;
+}
+
+.eyebrow {
+    margin: 0;
+    color: #93c5fd;
+    font-size: 13px;
+    font-weight: 800;
+    letter-spacing: 0.08em;
+    text-transform: uppercase;
+}
+
+.icon-button {
+    width: 42px;
+    height: 42px;
+    display: grid;
+    place-items: center;
+    padding: 0;
+    border-radius: 999px;
+    background: #334155;
+    color: white;
+    font-size: 28px;
+    line-height: 1;
+}
+
+.manager-section {
+    display: grid;
+    gap: 12px;
+    margin-top: 20px;
+}
+
+.manager-section h3 {
+    margin: 0;
+    font-size: 18px;
+}
+
+.game-choice-grid {
+    display: grid;
+    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
+    gap: 12px;
+}
+
+.game-choice {
+    display: grid;
+    gap: 6px;
+    justify-items: start;
+    text-align: left;
+    min-height: 96px;
+    padding: 16px;
+    border: 1px solid #475569;
+    background: #0f172a;
+    color: white;
+}
+
+.game-choice span {
+    font-size: 20px;
+}
+
+.game-choice small,
+.player-row small {
+    color: #94a3b8;
+    font-weight: 700;
+}
+
+.game-choice.selected {
+    border-color: #22c55e;
+    background: #052e16;
+}
+
+.field-label {
+    display: grid;
+    gap: 8px;
+    color: #cbd5e1;
+    font-weight: 800;
+}
+
+.modal-actions {
+    display: flex;
+    justify-content: flex-end;
+    gap: 12px;
+    margin-top: 20px;
+}
+
+.player-row span {
+    display: grid;
+    gap: 2px;
+}
+
+@media (max-width: 700px) {
+    .modal-actions {
+        flex-direction: column-reverse;
+    }
+}
